# EMBER · variables de entorno
# Copia este archivo a `.env` y completa los valores reales.
# `.env` está en .gitignore — nunca lo commitees.

# Secret para firmar los JWT de Auth.js. Generar con:
#   openssl rand -base64 32
AUTH_SECRET=

# ─── Internas (no editar a menos que cambies docker-compose) ──────────────
# URL del api desde el web container (red interna de Docker)
# API_URL=http://api:3001

# Connection string de Postgres desde el api container
# DATABASE_URL=postgres://ember:ember@db:5432/ember

# ─── Instalación por nodos · esta computadora como Backend ───────────────
# Frontend remoto autorizado para consumir la API. Acepta una lista separada
# por comas si usarás IP y hostname.
# CORS_ORIGINS=http://192.168.1.20:3000,http://frontend.local:3000
# FRONTEND_ORIGIN=http://192.168.1.20:3000

# DB remota cuando Postgres viva en otra computadora.
# DATABASE_URL=postgres://ember:ember@192.168.1.30:5432/ember

# Identidad visible del nodo Backend en /status.
# STATUS_BACKEND_DEVICE_NAME=PC Backend
# STATUS_BACKEND_DEVICE_HOST=192.168.1.21
# STATUS_BACKEND_CONTAINER_NAME=ember-api
# STATUS_BACKEND_PORT=3001

# Identidad esperada de los nodos remotos. Pueden quedar pendientes al inicio.
# STATUS_FRONTEND_DEVICE_NAME=PC Frontend
# STATUS_FRONTEND_DEVICE_HOST=192.168.1.20
# STATUS_FRONTEND_CONTAINER_NAME=ember-web
# STATUS_FRONTEND_PORT=3000
# STATUS_DATABASE_DEVICE_NAME=PC Base de datos
# STATUS_DATABASE_DEVICE_HOST=192.168.1.30
# STATUS_DATABASE_CONTAINER_NAME=ember-db
# STATUS_DATABASE_PORT=5432

# ─── SMTP · correos de confirmación de reserva ────────────────────────────
# Con Gmail: activa 2FA y crea una "App Password" (16 caracteres, sin espacios).
# Si se dejan vacías, las reservas se crean igual pero no se envía correo.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=
MAIL_FROM=EMBER · Casa Olivar <tu-correo@gmail.com>
